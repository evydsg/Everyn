<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- * Gold star icon (top-right) -->
        <TextView
            android:id="@+id/tvStar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*"
            android:textColor="@color/colorTextPrimary"
            android:textSize="36sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTitle"/>

        <!-- "Welcome back" heading -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Welcome back"
            android:textColor="@color/colorSurface"
            android:textSize="40sp"
            android:fontFamily="@font/cormorant_garamond"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvStar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Dressed like you meant it. -->
        <TextView
            android:id="@+id/tvSlogan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dressed like you meant it."
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:textStyle="italic"
            android:fontFamily="@font/cormorant_garamond"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

        <Button
            android:id="@+id/btnGoogle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_btn_gold"
            android:fontFamily="@font/outfit"
            android:text="Continue with Google"
            android:textColor="@color/colorSurface"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSlogan" />

        <!-- Divider: line — "or" — line -->
        <View
            android:id="@+id/dividerLeft"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="?attr/colorOnSurface"
            android:alpha="0.2"
            app:layout_constraintBottom_toBottomOf="@id/tvOr"
            app:layout_constraintEnd_toStartOf="@id/tvOr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnGoogle" />

        <TextView
            android:id="@+id/tvOr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="12dp"
            android:text="or"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:alpha="0.5"
            android:fontFamily="@font/outfit"
            app:layout_constraintEnd_toStartOf="@id/dividerRight"
            app:layout_constraintStart_toEndOf="@id/dividerLeft"
            app:layout_constraintTop_toBottomOf="@id/btnGoogle" />

        <View
            android:id="@+id/dividerRight"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:alpha="0.2"
            android:background="?attr/colorOnSurface"
            app:layout_constraintBottom_toBottomOf="@id/tvOr"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvOr"
            app:layout_constraintTop_toBottomOf="@id/btnGoogle"
            app:layout_constraintVertical_bias="0.809" />

        <!-- EMAIL Label -->
        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="EMAIL"
            android:textColor="@color/colorSurface"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="@font/outfit"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOr"/>

        <!-- Email input field -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="Enter your email address"
            android:textColorHint="@color/colorSurface"
            android:alpha="0.4"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:textColor="@color/colorSurface"
            android:textSize="15sp"
            android:fontFamily="@font/outfit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel" />

        <!-- Password Label -->
        <TextView
            android:id="@+id/tvPasswordLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="PASSWORD"
            android:textColor="@color/colorSurface"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="@font/outfit"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etEmail"/>

        <!-- Password input field -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="Enter your password"
            android:textColorHint="@color/colorSurface"
            android:alpha="0.4"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:textColor="@color/colorSurface"
            android:textSize="15sp"
            android:fontFamily="@font/outfit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel" />

        <!-- Forgot password link -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Forgot password"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:fontFamily="@font/outfit"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etPassword"/>

        <!--Sign In button -->
        <Button
            android:id="@+id/btnSignIn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="52dp"
            android:background="@drawable/bg_btn_gold"
            android:fontFamily="@font/outfit"
            android:textColor="@color/colorSurface"
            android:text="Sign In"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvForgotPassword" />

        <!-- Don't have account Footer -->
        <TextView
            android:id="@+id/tvCreateAccount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Don\'t have an account? Create one"
            android:textColor="@color/colorSurface"
            android:textSize="14sp"
            android:fontFamily="@font/outfit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnSignIn"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>