<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".AccountCreationActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:paddingTop="64dp"
        android:paddingBottom="32dp">

        <!-- Heading -->
        <TextView
            android:id="@+id/createAccountHeading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/create_account_heading"
            android:fontFamily="@font/cormorant_garamond"
            android:textSize="44sp"
            android:textColor="@color/colorTextPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/createAccountSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/create_account_subtitle"
            android:fontFamily="@font/cormorant_garamond"
            android:textStyle="italic"
            android:textSize="16sp"
            android:textColor="@color/colorGold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/createAccountHeading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Continue with Google -->
        <Button
            android:id="@+id/btnGoogle"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="@string/continue_with_google"
            android:fontFamily="@font/outfit"
            android:textSize="14sp"
            android:letterSpacing="0.02"
            android:textColor="@color/colorButtonText"
            android:background="@drawable/bg_btn_gold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/createAccountSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Divider -->
        <View
            android:id="@+id/dividerLeft"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/colorDashInactive"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnGoogle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/dividerOr"
            app:layout_constraintBottom_toBottomOf="@id/dividerOr"/>

        <TextView
            android:id="@+id/dividerOr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/or"
            android:fontFamily="@font/outfit"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:paddingHorizontal="12dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnGoogle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerRight"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/colorDashInactive"
            app:layout_constraintTop_toTopOf="@id/dividerOr"
            app:layout_constraintBottom_toBottomOf="@id/dividerOr"
            app:layout_constraintStart_toEndOf="@id/dividerOr"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Full Name Label -->
        <TextView
            android:id="@+id/labelFullName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_full_name"
            android:fontFamily="@font/outfit"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/dividerOr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Full Name Field -->
        <EditText
            android:id="@+id/inputFullName"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:hint="@string/hint_full_name"
            android:fontFamily="@font/outfit"
            android:textSize="14sp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelFullName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Email Label -->
        <TextView
            android:id="@+id/labelEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_email"
            android:fontFamily="@font/outfit"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/inputFullName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Email Field -->
        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:hint="@string/hint_email"
            android:fontFamily="@font/outfit"
            android:textSize="14sp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Password Label -->
        <TextView
            android:id="@+id/labelPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_password"
            android:fontFamily="@font/outfit"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/inputEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Password Field -->
        <EditText
            android:id="@+id/inputPassword"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:hint="@string/hint_password"
            android:fontFamily="@font/outfit"
            android:textSize="14sp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Confirm Password Label -->
        <TextView
            android:id="@+id/labelConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_confirm_password"
            android:fontFamily="@font/outfit"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/inputPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Confirm Password Field -->
        <EditText
            android:id="@+id/inputConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:hint="@string/hint_confirm_password"
            android:fontFamily="@font/outfit"
            android:textSize="14sp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelConfirmPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Create Account Button -->
        <Button
            android:id="@+id/btnCreateAccount"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="@string/create_account_cta"
            android:fontFamily="@font/outfit"
            android:textSize="14sp"
            android:letterSpacing="0.02"
            android:textColor="@color/colorButtonText"
            android:background="@drawable/bg_btn_gold"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/inputConfirmPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Already have an account -->
        <TextView
            android:id="@+id/tvSignIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/already_have_account"
            android:fontFamily="@font/outfit"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnCreateAccount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Terms of Service -->
        <TextView
            android:id="@+id/tvTerms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/terms_of_service"
            android:fontFamily="@font/outfit"
            android:textSize="11sp"
            android:textColor="@color/colorTextSecondary"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvSignIn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>