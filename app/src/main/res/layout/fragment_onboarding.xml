<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/colorBackground"
    android:paddingHorizontal="12dp">

    <!--Progress indicator row -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation ="horizontal"
        android:gravity ="center_vertical"
        android:layout_marginTop="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStarOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dash1"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:background="@color/colorGold"/>

        <View
            android:layout_width="8dp"
            android:layout_height="1dp"/>

        <View
            android:id="@+id/dash2"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:background="@color/colorDashInactive"/>

        <View
            android:layout_width="8dp"
            android:layout_height="1dp"/>

        <View
            android:id="@+id/dash3"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/colorDashInactive"/>

    </LinearLayout>

    <!-- Heading -->
    <TextView
        android:id="@+id/onboardingHeading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/cormorant_garamond"
        android:lineSpacingMultiplier="1.1"
        android:textColor="@color/colorTextPrimary"
        android:textSize="40sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/onboardingBody"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--Body copy - Outfit, small -->
    <TextView
        android:id="@+id/onboardingBody"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/outfit"
        android:textColor="@color/colorTextPrimary"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/onboardingHeading"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <!-- CTA Button -->
    <Button
        android:id="@+id/onboardingCTA"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_gold_pill"
        android:fontFamily="@font/outfit"
        android:textSize="12dp"
        android:letterSpacing="0.12"
        android:textColor="@color/colorButtonText"
        android:layout_marginBottom="12dp"
        android:layout_constraintBottom_toTopOf="@id/onboardingSkip"
        android:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--Skip Link -->
    <TextView
        android:id="@+id/onboardingSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/skip_for_now"
        android:fontFamily="@font/outfit"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="40dp"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>